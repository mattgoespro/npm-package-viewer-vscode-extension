{
  "name": "npm-package-viewer",
  "displayName": "NPM Package Viewer",
  "description": "Open npm package pages from import statements — in your browser or inside VS Code.",
  "version": "1.0.0",
  "publisher": "mattgoespro",
  "repository": {
    "type": "git",
    "url": "https://github.com/mattgoespro/npm-package-viewer-vscode-extension.git"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#cb3837",
    "theme": "dark"
  },
  "keywords": [
    "npm",
    "package",
    "import",
    "require",
    "module",
    "viewer",
    "registry",
    "browser",
    "vscode",
    "editor"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "npmPackageViewer.openInBrowser",
        "title": "Open npm Page in Browser",
        "category": "NPM Package Viewer"
      },
      {
        "command": "npmPackageViewer.openInWebview",
        "title": "Open npm Page in VS Code",
        "category": "NPM Package Viewer"
      },
      {
        "command": "npmPackageViewer.goToPackageJson",
        "title": "Go to package.json Dependency",
        "category": "NPM Package Viewer"
      }
    ],
    "configuration": {
      "title": "NPM Package Viewer",
      "properties": {
        "npmPackageViewer.defaultAction": {
          "type": "string",
          "default": "browser",
          "enum": [
            "browser",
            "webview"
          ],
          "enumDescriptions": [
            "Open npm pages in the default browser",
            "Open npm pages in a VS Code webview"
          ],
          "description": "Default action when clicking on a package."
        },
        "npmPackageViewer.registryUrl": {
          "type": "string",
          "default": "https://www.npmjs.com",
          "description": "Base URL of the npm registry to link to."
        },
        "npmPackageViewer.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens above import lines."
        },
        "npmPackageViewer.showHover": {
          "type": "boolean",
          "default": true,
          "description": "Show hover information on import lines."
        },
        "npmPackageViewer.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the package name in the status bar when the cursor is on an import line."
        }
      }
    },
    "submenus": [
      {
        "id": "npmPackageViewer.submenu",
        "label": "NPM Package Viewer"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "npmPackageViewer.submenu",
          "group": "navigation",
          "when": "editorTextFocus && resourceLangId =~ /^(javascript|typescript|javascriptreact|typescriptreact)$/"
        }
      ],
      "npmPackageViewer.submenu": [
        {
          "command": "npmPackageViewer.openInBrowser",
          "group": "1_open"
        },
        {
          "command": "npmPackageViewer.openInWebview",
          "group": "1_open"
        },
        {
          "command": "npmPackageViewer.goToPackageJson",
          "group": "2_navigate"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "pretest": "tsc -p ./tsconfig.test.json",
    "test": "node ./out-test/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
